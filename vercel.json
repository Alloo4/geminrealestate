{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "policy-data.json", "use": "@vercel/static" },
    { "src": "robots.txt", "use": "@vercel/static" },
    { "src": "sitemap.xml", "use": "@vercel/static" },
    { "src": "pml-terms/**", "use": "@vercel/static" },
    { "src": "policy/**", "use": "@vercel/static" },
    { "src": "private-money-loans/**", "use": "@vercel/static" },
    { "src": "transactional-funding/**", "use": "@vercel/static" },
    { "src": "transactional-lending/**", "use": "@vercel/static" },
    { "src": "assets/**", "use": "@vercel/static" }
  ],
  "redirects": [
    { "source": "/transactional-lending", "destination": "/transactional-funding/", "permanent": true },
    { "source": "/transactional-lending/", "destination": "/transactional-funding/", "permanent": true }
  ]
}
